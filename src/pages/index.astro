---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nehal Agrawal — GTM Engineer &amp; AI Sales Automation</title>
  <meta name="description" content="Nehal Agrawal is a GTM engineer building AI-powered sales pipelines and go-to-market systems. Writing about sales automation, HubSpot, n8n, and modern GTM.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/timeline.css">
  <link rel="stylesheet" href="/css/cards.css">
  <link rel="stylesheet" href="/css/modal.css">
  <link rel="stylesheet" href="/css/hovercard.css">
</head>
<body>

  <!-- NAVIGATION -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="#" class="nav-brand"><img src="/assets/images/nehal.png" alt="Nehal Agrawal" class="nav-avatar"></a>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#tools-workflows">Tools</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="#side-quests">Side quests</a></li>
        <li class="nav-icons">
          <a href="https://www.linkedin.com/in/thenehalagrawal" target="_blank" rel="noopener" class="nav-icon-link" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="mailto:nehalagrawal191@gmail.com" class="nav-icon-link" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
          <a href="https://x.com/NehallAgrawal" target="_blank" rel="noopener" class="nav-icon-link" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <header id="hero">
    <div class="section-inner">
      <h1 class="hero-title">Nehal Agrawal</h1>
      <p class="hero-subtitle">GTM engineer building AI-powered sales pipelines and go-to-market systems</p>
      <div class="hero-actions">
        <a href="#experience" class="btn-primary">View my work &rarr;</a>
        <a href="https://www.linkedin.com/in/thenehalagrawal" class="btn-ghost" target="_blank" rel="noopener">Get in touch</a>
      </div>
    </div>
  </header>

  <!-- WORKFLOWS -->
  <section id="tools-workflows">
    <div class="section-inner">
      <h2 class="section-label">tools &amp; workflows</h2>
      <p class="section-sub">things i've built and automated</p>
      <div id="workflows-grid"></div>
    </div>
  </section>

  <!-- EXPERIENCE / TIMELINE -->
  <section id="experience">
    <div class="section-inner">
      <h2 class="section-label">work experience &amp; projects</h2>
      <p class="section-sub">hover over any to explore</p>
      <div id="timeline-scroll-wrapper">
        <div id="timeline-container">
          <div id="timeline-brackets"></div>
          <div id="timeline-span-bars"></div>
          <div id="timeline-axis">
            <div id="timeline-year-labels"></div>
          </div>
          <div id="timeline-items"></div>
          <div id="timeline-pin"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW — auto-generated from latest posts -->
  <section id="blog-preview">
    <div class="section-inner">
      <h2 class="section-label">blog</h2>
      <div class="blog-preview-list">
        {allPosts.map((post) => {
          const d = new Date(post.data.date);
          const label = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          return (
            <a href={`/blog/${post.id}/`} class="blog-preview-row">
              <div class="blog-preview-img">
                {post.data.image && <img src={post.data.image} alt={post.data.imageAlt || post.data.title}>}
              </div>
              <div class="blog-preview-text">
                <div class="blog-preview-title">{post.data.title}</div>
                <div class="blog-preview-sub">{post.data.description}</div>
              </div>
              <span class="blog-preview-date">{label}</span>
            </a>
          );
        })}
      </div>
      <a href="/blog/" class="blog-preview-more">All posts &rarr;</a>
    </div>
  </section>

  <!-- SIDE QUESTS -->
  <section id="side-quests">
    <div class="section-inner">
      <h2 class="section-label">side quests</h2>
      <div id="side-quests-grid"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="section-inner">
      <h2 class="section-label">About Me</h2>
      <div class="about-layout">
        <p class="about-text">i'm creative and outspoken, and i spend most of my time at the intersection of AI and go-to-market. i love the outdoors, and i'm known for making canva invites for plans that absolutely don't need canva invites.</p>
        <img src="/assets/images/nehal_about.jpg" alt="Nehal Agrawal" class="about-photo">
      </div>
    </div>
  </section>

  <!-- TIMELINE HOVER CARD -->
  <div id="thc"><div class="thc-inner"></div></div>

  <!-- MODAL -->
  <div id="modal-overlay" class="modal-hidden" aria-hidden="true">
    <div id="modal-panel" role="dialog" aria-modal="true" tabindex="-1">
      <button id="modal-close" aria-label="Close panel">&#x2715;</button>
      <div id="modal-content"></div>
    </div>
  </div>

  <script src="/js/data.js" is:inline></script>
  <script src="/js/hovercard.js" is:inline></script>
  <script src="/js/timeline.js" is:inline></script>
  <script src="/js/modal.js" is:inline></script>
  <script src="/js/main.js" is:inline></script>
</body>
</html>
