<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>Tools & Workflows — Nehal Agrawal</title>
  <meta name="description" content="GTM tools and automation workflows built by Nehal Agrawal — outreach automation, AI sales systems, and go-to-market infrastructure.">
  <meta name="author" content="Nehal Agrawal">
  <link rel="canonical" href="https://nehall.com/tools/">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/cards.css">
  <style>
    #workflows-grid.workflows-grid-full {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      overflow-x: visible;
      flex-direction: unset;
    }
    #workflows-grid.workflows-grid-full .side-quest-card {
      flex: unset;
      min-width: unset;
      width: 100%;
    }
    #workflows-grid.workflows-grid-full .card-cover {
      height: 200px;
    }
    @media (max-width: 700px) {
      #workflows-grid.workflows-grid-full {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 480px) {
      #workflows-grid.workflows-grid-full {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <link rel="stylesheet" href="/css/modal.css">
  <link rel="stylesheet" href="/css/hovercard.css">
</head>
<body>

  <!-- NAVIGATION -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand"><img src="/assets/images/nehal.png" alt="Nehal Agrawal" class="nav-avatar"></a>
      <ul class="nav-links">
        <li><a href="/#about">About</a></li>
        <li><a href="/#experience">Experience</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/#side-quests">Side quests</a></li>
        <li class="nav-icons">
          <a href="https://www.linkedin.com/in/thenehalagrawal" target="_blank" rel="noopener" class="nav-icon-link" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/NehallAgrawal" target="_blank" rel="noopener" class="nav-icon-link" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <main style="padding: 48px 24px 80px;">
    <div class="section-inner">
      <a href="/" class="blog-back" style="display:inline-block;font-size:13px;font-weight:500;color:#94A3B8;text-decoration:none;margin-bottom:32px;">&larr; Back to portfolio</a>
      <h1 class="section-label" style="font-size:clamp(22px,4vw,32px);font-weight:800;margin-bottom:8px;">tools &amp; workflows</h1>
      <p style="font-size:14px;color:#64748B;margin-bottom:40px;">things i've built and automated</p>
      <div id="workflows-grid" class="workflows-grid-full"></div>
    </div>
  </main>

  <!-- MODAL -->
  <div id="modal-overlay" class="modal-hidden" aria-hidden="true">
    <div id="modal-panel" role="dialog" aria-modal="true" tabindex="-1">
      <button id="modal-close" aria-label="Close panel">&#x2715;</button>
      <div id="modal-content"></div>
    </div>
  </div>

  <script src="/js/data.js" is:inline></script>
  <script src="/js/modal.js" is:inline></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var grid = document.getElementById('workflows-grid');
      if (!grid || typeof WORKFLOWS_DATA === 'undefined') return;
      WORKFLOWS_DATA.forEach(function (wf) {
        var btn = document.createElement('button');
        btn.className = 'side-quest-card';
        btn.dataset.id = wf.id;
        var imgStyle = 'width:100%;height:100%;object-fit:cover;' + (wf.coverPosition ? 'object-position:' + wf.coverPosition + ';' : '');
        var coverHTML = wf.coverImage
          ? '<div class="card-cover"><img src="/' + wf.coverImage + '" alt="' + wf.title + '" loading="lazy" style="' + imgStyle + '"></div>'
          : '<div class="card-cover"><div class="card-color-placeholder" style="background:' + (wf.coverColor || '#E2E8F0') + '"></div></div>';
        btn.innerHTML = coverHTML + '<div class="card-body"><h3 class="card-title">' + wf.title + '</h3></div>';
        btn.addEventListener('click', function () { window.openModal(wf); });
        grid.appendChild(btn);
      });
    });
  </script>
</body>
</html>
