---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>GTM Engineering Blog — AI Sales Automation | Nehal Agrawal</title>
  <meta name="description" content="Practical writing on GTM engineering, AI in sales, and building modern go-to-market systems. By Nehal Agrawal.">
  <meta name="author" content="Nehal Agrawal">
  <link rel="canonical" href="https://nehall.com/blog/">
  <meta property="og:title" content="GTM Engineering Blog — AI Sales Automation | Nehal Agrawal">
  <meta property="og:description" content="Practical writing on GTM engineering, AI in sales, and building modern go-to-market systems. By Nehal Agrawal.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://nehall.com/blog/">
  <meta property="og:image" content="https://nehall.com/assets/images/nehal.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="GTM Engineering Blog — AI Sales Automation | Nehal Agrawal">
  <meta name="twitter:description" content="Practical writing on GTM engineering, AI in sales, and building modern go-to-market systems. By Nehal Agrawal.">
  <meta name="twitter:image" content="https://nehall.com/assets/images/nehal.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/blog.css">
</head>
<body>
  <main class="blog-listing-layout">
    <div class="blog-listing-inner">
      <header class="blog-listing-header">
        <h1 class="blog-listing-title">Writing</h1>
        <p class="blog-listing-sub">GTM, AI in sales, and building modern go-to-market systems.</p>
      </header>

      <div class="blog-post-list">
        {posts.map((post) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
            month: 'long',
            day: 'numeric',
            year: 'numeric',
          });
          return (
            <a href={`/blog/${post.id}/`} class="blog-post-row">
              <div class="blog-post-row-img">
                {post.data.image && <img src={post.data.image} alt={post.data.imageAlt || post.data.title}>}
              </div>
              <div class="blog-post-row-body">
                <div class="blog-post-row-meta">{formattedDate}</div>
                {post.data.series && (
                  <div class="blog-post-row-series">{post.data.series} · Part {post.data.seriesPart}</div>
                )}
                <h2 class="blog-post-row-title">{post.data.title}</h2>
                <p class="blog-post-row-excerpt">{post.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>
</body>
</html>
