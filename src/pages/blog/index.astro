---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by series
const seriesMap = new Map<string, typeof allPosts>();
allPosts.forEach(post => {
  if (post.data.series) {
    if (!seriesMap.has(post.data.series)) seriesMap.set(post.data.series, []);
    seriesMap.get(post.data.series)!.push(post);
  }
});

const seriesList = Array.from(seriesMap.entries()).map(([name, posts]) => {
  const sorted = posts.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
  return { name, count: posts.length, firstPost: sorted[0] };
});

const standaloneAndAll = allPosts;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>Writing — Nehal Agrawal</title>
  <meta name="description" content="Notes, essays, and technical walkthroughs on GTM engineering, AI agents, and revenue systems. By Nehal Agrawal.">
  <meta name="author" content="Nehal Agrawal">
  <link rel="canonical" href="https://nehall.com/blog/">
  <meta property="og:title" content="Writing — Nehal Agrawal">
  <meta property="og:description" content="Notes, essays, and technical walkthroughs on GTM engineering, AI agents, and revenue systems.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://nehall.com/blog/">
  <meta property="og:image" content="https://nehall.com/assets/images/nehal.png">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/blog.css">
</head>
<body>

  <nav class="blog-nav">
    <div class="blog-nav-inner">
      <a href="/" class="blog-nav-brand">Nehal Agrawal</a>
      <div class="blog-nav-links">
        <a href="/blog/" class="blog-nav-active">Writing</a>
      </div>
    </div>
  </nav>

  <main class="blog-listing-layout">
    <div class="blog-page-inner">

      <header class="blog-hero">
        <h1 class="blog-hero-title">building the future of go-to-market systems.</h1>
        <p class="blog-hero-sub">Notes, essays, and technical walkthroughs by Nehal Agrawal.</p>
        <p class="blog-hero-sub">GTM engineer at Invigilo AI.</p>
      </header>

      <!-- SERIES -->
      {seriesList.length > 0 && (
        <section class="blog-section">
          <div class="blog-section-header">
            <span class="blog-section-label">Series</span>
          </div>
          <div class="blog-series-grid">
            {seriesList.map(({ name, count, firstPost }) => (
              <a href={`/blog/${firstPost.id}/`} class="blog-series-card">
                <div class="blog-series-badges">
                  <span class="blog-series-badge-parts">{count} {count === 1 ? 'Part' : 'Parts'}</span>
                  <span class="blog-series-badge-status">In Progress</span>
                </div>
                <div class="blog-series-title">{name}</div>
                <div class="blog-series-desc">{firstPost.data.description}</div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ARTICLES -->
      <section class="blog-section">
        <div class="blog-section-header">
          <span class="blog-section-label">Articles</span>
        </div>
        <div class="blog-articles-list">
          {standaloneAndAll.map((post) => {
            const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            });
            return (
              <a href={`/blog/${post.id}/`} class="blog-article-row">
                {post.data.series && (
                  <div class="blog-article-series-tag">{post.data.series} · Part {post.data.seriesPart}</div>
                )}
                <div class="blog-article-top">
                  <span class="blog-article-title">{post.data.title}</span>
                  <span class="blog-article-date">{formattedDate}</span>
                </div>
                <p class="blog-article-desc">{post.data.description}</p>
              </a>
            );
          })}
        </div>
      </section>

    </div>
  </main>

</body>
</html>
