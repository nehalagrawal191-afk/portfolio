---
const { title, description, date, image, imageAlt, seriesPosts = [], currentPostId, seriesName } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>{title} — Nehal Agrawal</title>
  <meta name="description" content={description}>
  <meta name="author" content="Nehal Agrawal">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={Astro.url}>
  {image && <meta property="og:image" content={new URL(image, Astro.site)}>}
  <meta name="twitter:card" content="summary_large_image">
  <link rel="canonical" href={Astro.url}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/blog.css">
</head>
<body>

  <nav class="blog-nav">
    <div class="blog-nav-inner">
      <a href="/" class="blog-nav-brand">Nehal Agrawal</a>
      <div class="blog-nav-links">
        <a href="/blog/">Articles</a>
      </div>
    </div>
  </nav>

  <main class="blog-post-layout">
    <div class="blog-post-inner">

      <a href="/blog/" class="blog-back">&larr; All posts</a>

      <header class="post-header">
        <p class="post-meta">{formattedDate}</p>
        <h1 class="post-title">{title}</h1>
        <p class="post-subtitle">{description}</p>
        {image && (
          <div class="post-hero-img">
            <img src={image} alt={imageAlt || title}>
          </div>
        )}
      </header>

      {seriesPosts.length > 0 && (
        <div class="series-card">
          <div class="series-card-label">SERIES · {seriesPosts.length} PARTS</div>
          <div class="series-card-title">{seriesName}</div>
          <div class="series-card-parts">
            {seriesPosts.map((p: any) => (
              <a
                href={`/blog/${p.id}/`}
                class={`series-part-row${p.id === currentPostId ? ' series-part-current' : ''}`}
              >
                <span class="series-part-num">0{p.data.seriesPart}</span>
                <span class="series-part-title">{p.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <article class="post-body">
        <slot />
      </article>

      <footer class="post-footer">
        <a href="https://www.linkedin.com/in/thenehalagrawal" target="_blank" rel="noopener" aria-label="LinkedIn" class="post-footer-linkedin">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </footer>

    </div>
  </main>

</body>
</html>
